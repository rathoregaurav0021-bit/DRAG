venv.bak/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Jupyter Notebook
.ipynb_checkpoints

# GIS Data (large files)
backend/data/raw/
backend/data/processed/
*.gpkg
*.shp
*.shx
*.dbf
*.prj

# Ignore massive TIFFs and GeoJSONs globally...
*.tif
*.geojson

# ...but ALLOW the tiny, optimized web-data in the frontend
!frontend/public/data/
!frontend/public/data/*.tif
!frontend/public/data/*.geojson
!frontend/public/data/*.png

# OS generated files
.DS_Store
Thumbs.db

# Node dependencies and build output
node_modules/
.next/
dist/
out/
build/

